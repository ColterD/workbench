# Line-ending starter: LF everywhere by default, CRLF for Windows scripts.
* text=auto eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.sh text eol=lf
*.mjs text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.service text eol=lf
*.timer text eol=lf
*.conf text eol=lf
*.rb text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
